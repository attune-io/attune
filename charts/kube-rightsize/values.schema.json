{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "kube-rightsize Helm Values",
  "description": "Schema for validating kube-rightsize Helm chart values.yaml",
  "type": "object",
  "required": ["image"],
  "properties": {
    "replicaCount": {
      "type": "integer",
      "description": "Number of operator replicas (use 2 for HA with leader election)",
      "default": 1,
      "minimum": 1
    },
    "image": {
      "type": "object",
      "description": "Container image configuration",
      "required": ["repository"],
      "properties": {
        "repository": {
          "type": "string",
          "description": "Container image repository",
          "default": "ghcr.io/sebtardif/kube-rightsize"
        },
        "pullPolicy": {
          "type": "string",
          "description": "Image pull policy",
          "default": "IfNotPresent",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "tag": {
          "type": "string",
          "description": "Image tag (defaults to Chart appVersion if empty)",
          "default": ""
        }
      },
      "additionalProperties": false
    },
    "imagePullSecrets": {
      "type": "array",
      "description": "Image pull secrets",
      "default": [],
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        },
        "required": ["name"]
      }
    },
    "nameOverride": {
      "type": "string",
      "description": "Override the chart name",
      "default": ""
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override the full name",
      "default": ""
    },
    "serviceAccount": {
      "type": "object",
      "description": "ServiceAccount configuration",
      "properties": {
        "create": {
          "type": "boolean",
          "description": "Create a ServiceAccount",
          "default": true
        },
        "annotations": {
          "type": "object",
          "description": "Annotations to add to the ServiceAccount",
          "default": {},
          "additionalProperties": {
            "type": "string"
          }
        },
        "name": {
          "type": "string",
          "description": "ServiceAccount name (generated if not set)",
          "default": ""
        }
      },
      "additionalProperties": false
    },
    "podAnnotations": {
      "type": "object",
      "description": "Pod annotations",
      "default": {},
      "additionalProperties": {
        "type": "string"
      }
    },
    "podSecurityContext": {
      "type": "object",
      "description": "Pod security context",
      "properties": {
        "runAsNonRoot": {
          "type": "boolean",
          "description": "Require the pod to run as a non-root user",
          "default": true
        },
        "seccompProfile": {
          "type": "object",
          "description": "Seccomp profile for the pod",
          "properties": {
            "type": {
              "type": "string",
              "description": "Seccomp profile type",
              "default": "RuntimeDefault",
              "enum": ["RuntimeDefault", "Unconfined", "Localhost"]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "securityContext": {
      "type": "object",
      "description": "Container security context",
      "properties": {
        "allowPrivilegeEscalation": {
          "type": "boolean",
          "description": "Whether the container can gain more privileges than its parent process",
          "default": false
        },
        "capabilities": {
          "type": "object",
          "description": "Linux capabilities configuration",
          "properties": {
            "drop": {
              "type": "array",
              "description": "Capabilities to drop",
              "default": ["ALL"],
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "readOnlyRootFilesystem": {
          "type": "boolean",
          "description": "Whether the container has a read-only root filesystem",
          "default": true
        },
        "runAsNonRoot": {
          "type": "boolean",
          "description": "Require the container to run as a non-root user",
          "default": true
        },
        "runAsUser": {
          "type": "integer",
          "description": "The UID to run the container process as",
          "default": 65532,
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "resources": {
      "type": "object",
      "description": "Operator pod resources",
      "properties": {
        "limits": {
          "type": "object",
          "description": "Resource limits",
          "properties": {
            "cpu": {
              "type": "string",
              "description": "CPU limit",
              "default": "500m"
            },
            "memory": {
              "type": "string",
              "description": "Memory limit",
              "default": "128Mi"
            }
          },
          "additionalProperties": false
        },
        "requests": {
          "type": "object",
          "description": "Resource requests",
          "properties": {
            "cpu": {
              "type": "string",
              "description": "CPU request",
              "default": "100m"
            },
            "memory": {
              "type": "string",
              "description": "Memory request",
              "default": "64Mi"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "nodeSelector": {
      "type": "object",
      "description": "Node selector",
      "default": {},
      "additionalProperties": {
        "type": "string"
      }
    },
    "tolerations": {
      "type": "array",
      "description": "Tolerations",
      "default": [],
      "items": {
        "type": "object"
      }
    },
    "affinity": {
      "type": "object",
      "description": "Affinity rules",
      "default": {}
    },
    "leaderElection": {
      "type": "object",
      "description": "Leader election (enable for HA with replicaCount > 1)",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable leader election",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "metrics": {
      "type": "object",
      "description": "Metrics endpoint configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable metrics endpoint",
          "default": true
        },
        "port": {
          "type": "integer",
          "description": "Metrics port",
          "default": 8080,
          "minimum": 1,
          "maximum": 65535
        },
        "serviceMonitor": {
          "type": "object",
          "description": "ServiceMonitor configuration for Prometheus Operator",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Create a ServiceMonitor for Prometheus Operator",
              "default": false
            },
            "additionalLabels": {
              "type": "object",
              "description": "Additional labels for the ServiceMonitor",
              "default": {},
              "additionalProperties": {
                "type": "string"
              }
            },
            "interval": {
              "type": "string",
              "description": "Scrape interval",
              "default": "30s"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "logging": {
      "type": "object",
      "description": "Logging configuration",
      "properties": {
        "level": {
          "type": "string",
          "description": "Log level",
          "default": "info",
          "enum": ["debug", "info", "warn", "error"]
        },
        "format": {
          "type": "string",
          "description": "Log format",
          "default": "json",
          "enum": ["json", "text"]
        }
      },
      "additionalProperties": false
    },
    "webhooks": {
      "type": "object",
      "description": "Webhook configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable admission webhooks (requires cert-manager or manual TLS)",
          "default": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
