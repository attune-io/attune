{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "Number of operator replicas (use 2 for HA with leader election)"
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "default": "ghcr.io/sebtardiflabs/kube-rightsize"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"],
          "default": "IfNotPresent"
        },
        "tag": {
          "type": "string",
          "default": "",
          "description": "Image tag (defaults to Chart appVersion)"
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" }
        },
        "required": ["name"]
      },
      "default": []
    },
    "nameOverride": {
      "type": "string",
      "default": ""
    },
    "fullnameOverride": {
      "type": "string",
      "default": ""
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean",
          "default": true
        },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "default": {}
        },
        "name": {
          "type": "string",
          "default": ""
        }
      }
    },
    "podAnnotations": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "default": {}
    },
    "podSecurityContext": {
      "type": "object",
      "description": "Pod-level security context"
    },
    "securityContext": {
      "type": "object",
      "description": "Container-level security context"
    },
    "resources": {
      "type": "object",
      "description": "Operator pod resource requests and limits",
      "properties": {
        "limits": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "requests": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "priorityClassName": {
      "type": "string",
      "default": "",
      "description": "Priority class name for the operator pod"
    },
    "nodeSelector": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "default": {}
    },
    "tolerations": {
      "type": "array",
      "items": { "type": "object" },
      "default": []
    },
    "affinity": {
      "type": "object",
      "default": {}
    },
    "topologySpreadConstraints": {
      "type": "array",
      "items": { "type": "object" },
      "default": []
    },
    "leaderElection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "default": 8080
        },
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "additionalLabels": {
              "type": "object",
              "additionalProperties": { "type": "string" },
              "default": {}
            },
            "interval": {
              "type": "string",
              "pattern": "^([0-9]+(ns|us|ms|s|m|h))+$",
              "default": "30s"
            }
          }
        }
      }
    },
    "grafanaDashboard": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "additionalLabels": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "default": {}
        }
      }
    },
    "webhooks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable admission webhooks (requires cert-manager)"
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "prometheusPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "default": 9090,
          "description": "TCP port allowed for Prometheus backend pods"
        }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "description": "Cluster-wide RightSizeDefaults CR",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "updateStrategy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["Observe", "Recommend", "OneShot", "Canary", "Auto"],
              "default": "Recommend"
            },
            "cooldown": {
              "type": "string",
              "pattern": "^([0-9]+(ns|us|ms|s|m|h))+$",
              "default": "1h"
            },
            "autoRevert": {
              "type": "boolean",
              "default": true
            },
            "resizeMethod": {
              "type": "string",
              "enum": ["InPlaceOnly", "InPlaceOrEvict"],
              "default": "InPlaceOnly"
            },
            "maxConcurrentResizes": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 1
            },
            "schedule": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "windows": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "start": { "type": "string", "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$" },
                      "end": { "type": "string", "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$" }
                    },
                    "required": ["start", "end"]
                  }
                },
                "daysOfWeek": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"]
                  }
                },
                "timezone": {
                  "type": "string",
                  "default": "UTC"
                }
              }
            },
            "maxTotalCpuIncrease": {
              "type": "string",
              "description": "Per-cycle CPU increase budget (e.g. 2000m)"
            },
            "maxTotalMemoryIncrease": {
              "type": "string",
              "description": "Per-cycle memory increase budget (e.g. 4Gi)"
            },
            "maxCpuChangePercent": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "description": "Maximum CPU change per resize as a percentage of current request"
            },
            "maxMemoryChangePercent": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "description": "Maximum memory change per resize as a percentage of current request"
            },
            "export": {
              "type": "object",
              "additionalProperties": false,
              "description": "Export recommendations to a ConfigMap",
              "properties": {
                "configMap": {
                  "type": "boolean",
                  "default": false,
                  "description": "Enable exporting recommendations to ConfigMaps (one per workload)"
                }
              }
            }
          }
        }
      }
    },
    "clusterSize": {
      "type": "string",
      "enum": ["", "small", "medium", "large", "xlarge"],
      "default": "",
      "description": "Cluster size preset: sets resources, rate limits, and replica count. Empty means no preset."
    },
    "prometheusQPS": {
      "type": "number",
      "exclusiveMinimum": 0,
      "default": 10,
      "description": "Prometheus query rate limit (queries per second)"
    },
    "prometheusBurst": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "default": 20,
      "description": "Prometheus query burst allowance"
    },
    "collectorTTL": {
      "type": "string",
      "pattern": "^([0-9]+(ns|us|ms|s|m|h))+$",
      "default": "10m",
      "description": "Cache TTL for unused Prometheus connections (Go duration, e.g. 10m, 1h30m)"
    },
    "prometheusTimeout": {
      "type": "string",
      "pattern": "^([0-9]+(ns|us|ms|s|m|h))+$",
      "default": "5m",
      "description": "Maximum time for Prometheus queries per reconciliation cycle (Go duration, e.g. 5m, 10m)"
    },
    "maxConcurrentReconciles": {
      "type": ["integer", "string"],
      "minimum": 1,
      "default": "",
      "description": "Maximum number of RightSizePolicy reconciles running in parallel. Auto-set by clusterSize preset if empty."
    },
    "watchNamespaces": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Namespaces to watch for RightSizePolicy resources. Empty means all namespaces. Reduces informer cache memory on large clusters."
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {
          "oneOf": [
            { "type": "string", "enum": ["debug", "info", "warn", "error"] },
            { "type": "integer", "minimum": 0, "maximum": 10, "description": "Numeric V-level for verbose logging (e.g. 2 for trace)" }
          ],
          "default": "info"
        },
        "format": {
          "type": "string",
          "enum": ["json", "text"],
          "default": "json"
        }
      }
    }
  }
}