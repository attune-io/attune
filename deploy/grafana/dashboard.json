{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for kube-rightsize metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "kube-rightsize operator overview: resize operations, savings, recommendations, and operator health.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Total Resizes",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(kube_rightsize_resize_total)",
          "legendFormat": "resizes"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Total Reverts",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(kube_rightsize_reverts_total)",
          "legendFormat": "reverts"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "CPU Cores Saved",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(kube_rightsize_savings_cpu_cores_total)",
          "legendFormat": "cores"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "purple", "value": null }
            ]
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Memory Saved",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(kube_rightsize_savings_memory_bytes_total)",
          "legendFormat": "bytes"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 5 },
      "id": 13,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Estimated Monthly Savings",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(kube_rightsize_savings_estimated_monthly_dollars)",
          "legendFormat": "$/month"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Resize Operations",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Resize Operations by Result",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (result) (rate(kube_rightsize_resize_total[$__rate_interval]))",
          "legendFormat": "{{ result }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Reverts by Reason",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (reason) (rate(kube_rightsize_reverts_total[$__rate_interval]))",
          "legendFormat": "{{ reason }}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Recommendations",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 7,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Recommended CPU (cores)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "kube_rightsize_recommendation_cpu_cores{namespace=~\"$namespace\"}",
          "legendFormat": "{{ workload }}/{{ container }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 8,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Recommended Memory",
      "type": "timeseries",
      "targets": [
        {
          "expr": "kube_rightsize_recommendation_memory_bytes{namespace=~\"$namespace\"}",
          "legendFormat": "{{ workload }}/{{ container }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          },
          "min": 0,
          "max": 1,
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "id": 9,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Recommendation Confidence",
      "type": "timeseries",
      "targets": [
        {
          "expr": "kube_rightsize_confidence{namespace=~\"$namespace\"}",
          "legendFormat": "{{ workload }}/{{ container }}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 103,
      "title": "Operator Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Reconcile Duration",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(kube_rightsize_reconcile_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p99"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(kube_rightsize_reconcile_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 12, "y": 32 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Prometheus Query Duration",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, query_type) (rate(kube_rightsize_prometheus_query_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p99 {{query_type}}"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le, query_type) (rate(kube_rightsize_prometheus_query_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p50 {{query_type}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 32 },
      "id": 12,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Query Errors",
      "type": "stat",
      "targets": [
        {
          "expr": "sum by (namespace, query_type) (rate(kube_rightsize_prometheus_query_errors_total[$__rate_interval]))",
          "legendFormat": "{{namespace}} {{query_type}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["kubernetes", "kube-rightsize", "cost-optimization"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(kube_rightsize_recommendation_cpu_cores, namespace)",
        "name": "namespace",
        "query": "label_values(kube_rightsize_recommendation_cpu_cores, namespace)",
        "regex": "",
        "type": "query",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "kube-rightsize",
  "uid": "kube-rightsize-overview",
  "version": 1
}