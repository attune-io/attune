{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^\\.github/workflows/.*\\.ya?ml$"],
      "matchStrings": [
        "PROMETHEUS_CHART_VERSION:\\s*[\"']?(?<currentValue>[^\"'\\s]+)[\"']?"
      ],
      "depNameTemplate": "prometheus",
      "packageNameTemplate": "prometheus-community/prometheus",
      "datasourceTemplate": "helm",
      "registryUrlTemplate": "https://prometheus-community.github.io/helm-charts"
    },
    {
      "customType": "regex",
      "fileMatch": ["^\\.github/workflows/.*\\.ya?ml$"],
      "matchStrings": [
        "PROMETHEUS_IMAGE:\\s*[\"']?quay\\.io/prometheus/prometheus:(?<currentValue>v[^\"'\\s]+)[\"']?"
      ],
      "depNameTemplate": "quay.io/prometheus/prometheus",
      "datasourceTemplate": "docker"
    }
  ]
}